Import "../Core/Lib_Malterlib.MTarget"
Import "Apps/*/*.MHeader"

%Group "{Malterlib}/{Lib_Malterlib_Concurrency}"
{
	Property.MalterlibConcurrency_DistributedActors true
	%Group Concurrency
	{
		%Group Include
		{
			Compile.Type "C++"
			{
				!!DocumentationEnabled true
			}
			%File "Include/Mib/Concurrency/^*"
		}
		%File "Source/^*"
		%Group Documentation
		{
			%File "Documentation/*"
		}
	}

	%Dependency Lib_Malterlib_Web
	{
		Dependency.Indirect true
	}
}

Property
{
/*
	MalterlibConcurrency_DistributedActorsInAnyTarget_Template "true"
	{
		&
		{
			!Explodee ""
			"true" "@(Builtin.Function->GetProperty('Property', 'MalterlibConcurrency_DistributedActors', '@(Explodee)'))"
			"true" "@(Builtin.Function->GetProperty('Property', 'TargetIsExecutable', '@(Explodee)'))"
		}
	}
	MalterlibConcurrency_DistributedActorsInAnyTarget "@(Builtin.Function->ExplodeList('@(Workspace.AllTargets)', ';', 'MalterlibConcurrency_DistributedActorsInAnyTarget_Template'))"
	MalterlibConcurrency_DistributedActors false
	{
		!!MalterlibConcurrency_DistributedActors ""
	}
	*/
	MalterlibConcurrency_DistributedActors true
	{
		!!MalterlibConcurrency_DistributedActors ""
	}
}

Compile
{
	!!CompileDialect "C"
	PreprocessorDefines "DMibEnableDistributedActors;@(Compile.PreprocessorDefines)"
	{
		!!MalterlibConcurrency_DistributedActors true
	}
}

Property
{
	MalterlibLibrary_Concurrency true
	{
		&
		{
			MalterlibLibrary_Concurrency ""
			MalterlibLibrary_All true
		}
	}
	MalterlibSubLibraries "Concurrency;@(MalterlibSubLibraries)"
	{
		!!MalterlibLibrary_Concurrency true
	}
	MalterlibLibrarySeparate_Lib_Malterlib_Concurrency true
//	MalterlibSubLibrarySeparate_Lib_Malterlib_Concurrency true
	MalterlibIncludeRoots "@('Include'->MakeAbsolute());@(MalterlibIncludeRoots)"
	{
		!!MalterlibLibrary_Concurrency true
	}
}

%Group "{Test}/{Malterlib_Concurrency}"
{
	Property.MalterlibConcurrency_DistributedActors true

	Property.MalterlibLinkWithOpenSSL true
	%Group "Tests"
	{
		%File "Test/*"
	}
	%Dependency Lib_Malterlib_Network
	%Dependency Lib_Malterlib_Concurrency
	%Dependency Lib_Malterlib_Web
}

Property
{
	!!MalterlibEnableInternalTests true
	
	MalterlibTests "Malterlib_Concurrency;@(MalterlibTests)"
	MalterlibTestExtraGroups_Malterlib_Concurrency "{Test}/{Malterlib_Concurrency}"
	MalterlibTestFiles_Malterlib_Concurrency ""
}

%Workspace "Apps_Malterlib_Concurrency"
{
	&
	{
		MalterlibEnableInternalWorkspaces true
	}
	
	Property.MalterlibPostCopyProject "Malterlib_Concurrency"
	{
		!!TargetIsExecutable true
	}
	
	Property.MalterlibLog_Severities "Error;Critical;Warning;Info"
	{
		!!MalterlibLog_EnableVerboseDebugLog false
	}

	%Target "@(Malterlib_Concurrency_App_Targets)"
}

Property
{
	MalterlibConcurrency_DebugActorCallstacks "" // User: Set to true to enable actor calls callstack debugging
	{
		!!MalterlibConcurrency_DebugActorCallstacks ""
	}

	MalterlibConcurrency_DebugBlockDestroy "" // User: Set to true to enable debug of block destroy for concurrency manager
	{
		!!MalterlibConcurrency_DebugBlockDestroy ""
	}
}

Compile
{
	!!LanguageFamily .NET

	PreprocessorDefines "DMibConfig_Concurrency_DebugActorCallstacks;@(Compile.PreprocessorDefines)"
	{
		!!MalterlibConcurrency_DebugActorCallstacks "true"
	}
	PreprocessorDefines "DMibConfig_Concurrency_DebugBlockDestroy;@(Compile.PreprocessorDefines)"
	{
		!!MalterlibConcurrency_DebugBlockDestroy "true"
	}
}

// C and C++ Settings
Compile
{
	&
	{
		LanguageFamily Native
		|
		{
			CompileDialect C
		}
	}

	PreprocessorDefines "DMibConfig_Concurrency_DebugActorCallstacks=1;@(Compile.PreprocessorDefines)"
	{
		!!MalterlibConcurrency_DebugActorCallstacks "true"
	}
	PreprocessorDefines "DMibConfig_Concurrency_DebugActorCallstacks=0;@(Compile.PreprocessorDefines)"
	{
		!!MalterlibConcurrency_DebugActorCallstacks "false"
	}

	PreprocessorDefines "DMibConfig_Concurrency_DebugBlockDestroy=1;@(Compile.PreprocessorDefines)"
	{
		!!MalterlibConcurrency_DebugBlockDestroy "true"
	}
	PreprocessorDefines "DMibConfig_Concurrency_DebugBlockDestroy=0;@(Compile.PreprocessorDefines)"
	{
		!!MalterlibConcurrency_DebugBlockDestroy "false"
	}
}

